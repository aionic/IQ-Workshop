# ============================================================================
# .env.example — Environment variable template for IQ Foundry Agent Lab
# Copy to .env and fill in values: cp .env.example .env
# ============================================================================

# --- Local Development (Docker Compose) ---
# SQL Server SA password (local container only — NEVER used in Azure)
SA_PASSWORD=YourStr0ngP@ssword!

# Database auth mode: "password" for local, "token" for Azure
DB_AUTH_MODE=password

# SQL Server connection target
AZURE_SQL_SERVER_FQDN=localhost
AZURE_SQL_DATABASE_NAME=sqldb-iq

# --- Azure Deployment (Managed Identity) ---
# Uncomment and set when deploying to Azure:
# DB_AUTH_MODE=token
# AZURE_SQL_SERVER_FQDN=sql-iq-lab-dev.database.windows.net
# AZURE_SQL_DATABASE_NAME=sqldb-iq
# AZURE_CLIENT_ID=TODO-client-id-of-id-iq-tools-managed-identity

# --- Observability ---
# App Insights connection string (from Bicep output)
# Leave empty for local dev (logging falls back to console)
APPLICATIONINSIGHTS_CONNECTION_STRING=

# --- Optional: Teams Integration ---
# Incoming Webhook URL for Teams channel (leave empty to use stub)
TEAMS_WEBHOOK_URL=

# --- Testing ---
# Set to "true" to run integration tests against local SQL container
TEST_USE_DB=false
