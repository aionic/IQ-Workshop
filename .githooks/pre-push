#!/usr/bin/env bash
# .githooks/pre-push — Quality gates before push
# Install: git config core.hooksPath .githooks
#
# Gates:
#   1. Unit tests pass (pytest)
#   2. Lint passes (ruff check)
#   3. Bash/PS1 script alignment (no hardcoded defaults, pairs exist)
#
# Skip with: git push --no-verify

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

REPO_ROOT="$(git rev-parse --show-toplevel)"
FAILED=0

echo ""
echo "=========================================="
echo "  Pre-push quality gates"
echo "=========================================="

# ─── Gate 1: Unit tests ──────────────────────────────────────────────
echo -e "\n${YELLOW}[1/3] Running unit tests...${NC}"
if (cd "$REPO_ROOT/services/api-tools" && uv run pytest -q --tb=short 2>&1); then
  echo -e "${GREEN}✓ Tests passed${NC}"
else
  echo -e "${RED}✗ Tests FAILED — fix before pushing${NC}"
  FAILED=1
fi

# ─── Gate 2: Lint ────────────────────────────────────────────────────
echo -e "\n${YELLOW}[2/3] Running ruff lint...${NC}"
if (cd "$REPO_ROOT/services/api-tools" && uv run ruff check . 2>&1); then
  echo -e "${GREEN}✓ Lint passed${NC}"
else
  echo -e "${RED}✗ Lint FAILED — run 'uv run ruff check --fix .' to auto-fix${NC}"
  FAILED=1
fi

# ─── Gate 3: Script alignment ────────────────────────────────────────
echo -e "\n${YELLOW}[3/3] Checking script alignment...${NC}"
ALIGN_FAIL=0

# 3a. Every .ps1 should have a matching .sh (and vice-versa) for deployment scripts
SCRIPT_PAIRS=(
  "deploy"
  "seed-database"
  "smoke-test"
  "register-agent"
)
for name in "${SCRIPT_PAIRS[@]}"; do
  ps1="$REPO_ROOT/scripts/${name}.ps1"
  sh="$REPO_ROOT/scripts/${name}.sh"
  if [[ -f "$ps1" && ! -f "$sh" ]]; then
    echo -e "${RED}  ✗ Missing bash counterpart: scripts/${name}.sh${NC}"
    ALIGN_FAIL=1
  elif [[ -f "$sh" && ! -f "$ps1" ]]; then
    echo -e "${RED}  ✗ Missing PS1 counterpart: scripts/${name}.ps1${NC}"
    ALIGN_FAIL=1
  fi
done

# 3b. No hardcoded resource-group defaults in bash scripts
for sh_file in "$REPO_ROOT"/scripts/*.sh; do
  [[ -f "$sh_file" ]] || continue
  basename_file="$(basename "$sh_file")"
  # Look for RESOURCE_GROUP="rg-...' (hardcoded default instead of env var)
  if grep -qE 'RESOURCE_GROUP="rg-' "$sh_file" 2>/dev/null; then
    echo -e "${RED}  ✗ Hardcoded RESOURCE_GROUP default in scripts/${basename_file}${NC}"
    ALIGN_FAIL=1
  fi
done

# 3c. No hardcoded resource-group defaults in PS1 scripts
for ps1_file in "$REPO_ROOT"/scripts/*.ps1; do
  [[ -f "$ps1_file" ]] || continue
  basename_file="$(basename "$ps1_file")"
  if grep -qE '\$ResourceGroup\s*=\s*"rg-' "$ps1_file" 2>/dev/null; then
    echo -e "${RED}  ✗ Hardcoded ResourceGroup default in scripts/${basename_file}${NC}"
    ALIGN_FAIL=1
  fi
done

if [[ "$ALIGN_FAIL" -eq 0 ]]; then
  echo -e "${GREEN}✓ Script alignment OK${NC}"
else
  echo -e "${RED}✗ Script alignment FAILED${NC}"
  FAILED=1
fi

# ─── Summary ─────────────────────────────────────────────────────────
echo ""
if [[ "$FAILED" -eq 0 ]]; then
  echo -e "${GREEN}=========================================="
  echo -e "  All gates passed — pushing"
  echo -e "==========================================${NC}"
  exit 0
else
  echo -e "${RED}=========================================="
  echo -e "  Push BLOCKED — fix the issues above"
  echo -e "  (skip with: git push --no-verify)"
  echo -e "==========================================${NC}"
  exit 1
fi
